# Dolibarr Environment Variables
# Copy this to .env and fill in your local values
# DO NOT COMMIT .env to Git (it contains secrets)

# Database
DOLIBARR_DB_HOST=localhost
DOLIBARR_DB_PORT=3306
DOLIBARR_DB_NAME=dolibarr_dev
DOLIBARR_DB_USER=dolibarr_user
DOLIBARR_DB_PASS=secure_password_here

# Admin credentials (for install wizard)
DOLIBARR_ADMIN_LOGIN=admin
DOLIBARR_ADMIN_PASS=admin_password_here

# Email (for outbound invoices, remittances, etc.)
DOLIBARR_SMTP_FROM=southsidesupplies.yes@gmail.com
DOLIBARR_SMTP_HOST=smtp.gmail.com
DOLIBARR_SMTP_PORT=587
DOLIBARR_SMTP_USER=your-gmail@gmail.com
DOLIBARR_SMTP_PASS=your-app-password

# API credentials (for Reckon import and website integration)
DOLIBARR_API_KEY=your_api_key_here
DOLIBARR_API_URL=http://dolibarr.local/api/index.php

# Optional: For future live deployment
# DOLIBARR_LIVE_DB_NAME=dolibarr_prod
# DOLIBARR_LIVE_DB_USER=dolibarr_prod_user
# DOLIBARR_LIVE_DB_PASS=prod_password_here
