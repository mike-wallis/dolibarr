# Credentials — never commit
.env

# Dolibarr config (contains DB password)
conf/conf.php
htdocs/conf/conf.php

# Dolibarr data files (generated documents, uploads)
documents/

# Dolibarr core — third-party code, not ours.
# Custom source files live in custom/ and are tracked.
# Deploy scripts copy them into htdocs/ at install/update time.
htdocs/
dolibarr-scripts/

# Setup screenshots
images/

# Import data (may contain real business data). ** so this also matches
# subfolders like imports/payroll/ — a plain * only matches imports/ itself.
imports/**/*.csv
imports/**/*.xlsx
imports/**/*.xls
imports/raw_samples/

# ATO reference PDFs/spreadsheets scraped for payroll tax tables — large and
# fully reproducible from the documented URLs/Playwright scripts in CLAUDE.md
# (see "Playwright for ATO Data Scraping"). The parsed CSV output that actually
# matters is committed separately to custom/modules/payroll/data/.
imports/**/*.pdf
imports/payroll/pdf_pages/

# Database dumps
*.sql
# Exception: custom module install/schema SQL files are source code
!custom/modules/*/sql/*.sql

# Logs
*.log

# Claude Code local memory (not project code)
.claude/
